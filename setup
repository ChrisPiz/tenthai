#!/usr/bin/env bash
# Henge setup script — deterministic install for Claude Code, Claude Desktop, and Cursor.
#
# Usage:
#   ./setup                          # auto-detect installed hosts and register for each
#   ./setup --host claude-code       # only Claude Code
#   ./setup --host claude-desktop    # only Claude Desktop
#   ./setup --host cursor            # only Cursor
#   ./setup --host all               # all three (even if not detected)
#   ./setup --skip-validate          # skip the API-key validation step
#
# Prereqs: a populated .env in the repo root (cp .env.example .env first, then fill in keys).
# The script does NOT prompt for keys — your wrapper (LLM agent or human) is expected to
# write them into .env before running ./setup. This keeps the setup non-interactive and
# friendly to LLM-driven Bash tools whose stdin is not a TTY.

set -euo pipefail

HENGE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_VALUE="auto"
SKIP_VALIDATE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host) HOST_VALUE="${2:-}"; shift 2 ;;
    --host=*) HOST_VALUE="${1#--host=}"; shift ;;
    --skip-validate) SKIP_VALIDATE=1; shift ;;
    -h|--help)
      sed -n '2,16p' "$0"
      exit 0
      ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

# ───── pretty output ─────
say()  { printf "\033[1;36m▸\033[0m %s\n" "$*"; }
ok()   { printf "\033[1;32m✓\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m!\033[0m %s\n" "$*"; }
fail() { printf "\033[1;31m✗\033[0m %s\n" "$*" >&2; exit 1; }

# ───── step 1: locate Python ≥3.11 ─────
say "Locating Python ≥3.11"
PY=""
for cand in \
  python3.13 python3.12 python3.11 \
  /opt/homebrew/bin/python3.13 /opt/homebrew/bin/python3.12 /opt/homebrew/bin/python3.11 \
  /usr/local/bin/python3.13 /usr/local/bin/python3.12 /usr/local/bin/python3.11
do
  if "$cand" --version >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done

# Try existing pyenv versions
if [[ -z "$PY" && -d "$HOME/.pyenv/versions" ]]; then
  for v in "$HOME"/.pyenv/versions/3.13.* "$HOME"/.pyenv/versions/3.12.* "$HOME"/.pyenv/versions/3.11.*; do
    [[ -d "$v" ]] || continue
    if [[ -x "$v/bin/python3" ]]; then
      PY="$v/bin/python3"
      break
    fi
  done
fi

# Last resort: install via pyenv (no sudo)
if [[ -z "$PY" ]]; then
  warn "No Python ≥3.11 found. Installing 3.11.9 via pyenv (~10 min, no sudo)…"
  if ! command -v pyenv >/dev/null 2>&1; then
    if [[ ! -d "$HOME/.pyenv" ]]; then
      curl -fsSL https://pyenv.run | bash
    fi
  fi
  export PYENV_ROOT="$HOME/.pyenv"
  export PATH="$PYENV_ROOT/bin:$PATH"
  if command -v pyenv >/dev/null 2>&1; then
    eval "$(pyenv init -)"
    pyenv install 3.11.9 || warn "pyenv install reported issues (lzma warnings are non-fatal)"
  fi
  PY="$HOME/.pyenv/versions/3.11.9/bin/python3.11"
fi

[[ -x "$(command -v "$PY" 2>/dev/null || echo "$PY")" ]] || fail "Could not locate or install a Python ≥3.11 interpreter."
PY_VERSION="$("$PY" --version 2>&1)"
ok "Python: $PY ($PY_VERSION)"

# ───── step 2: venv + editable install ─────
cd "$HENGE_DIR"
if [[ ! -x ".venv/bin/python" ]]; then
  say "Creating venv at $HENGE_DIR/.venv"
  "$PY" -m venv .venv
else
  ok "Venv already exists"
fi

say "Upgrading pip + installing Henge in editable mode"
.venv/bin/pip install --upgrade pip --quiet
.venv/bin/pip install -e . --quiet
ok "Editable install complete"

# Cross-cwd sanity check — proves the package is importable without cd
if ! ( cd "${TMPDIR:-/tmp}" && "$HENGE_DIR/.venv/bin/python" -c "import henge" 2>/dev/null ); then
  fail "Sanity check failed: 'import henge' from a different cwd does not work. Re-run ./setup."
fi
ok "Cross-cwd import works"

# ───── step 3: ensure .env exists ─────
ENV_FILE="$HENGE_DIR/.env"
if [[ ! -f "$ENV_FILE" ]]; then
  cp "$HENGE_DIR/.env.example" "$ENV_FILE"
  warn ".env was missing — copied .env.example. Edit $ENV_FILE before continuing."
  fail "Set ANTHROPIC_API_KEY (and OPENAI_API_KEY or VOYAGE_API_KEY) in .env, then rerun ./setup."
fi

if grep -qE '^ANTHROPIC_API_KEY=(sk-ant-\.\.\.)?\s*$' "$ENV_FILE"; then
  fail "ANTHROPIC_API_KEY in .env still has the placeholder. Set the real key, then rerun ./setup."
fi

# ───── step 4: validate keys ─────
if [[ $SKIP_VALIDATE -eq 1 ]]; then
  warn "Skipping key validation (--skip-validate)"
else
  say "Validating keys against APIs (5s)…"
  set +e
  VALIDATE_OUTPUT=$(
    cd "$HENGE_DIR"
    ./.venv/bin/python -m henge.server </dev/null >/tmp/henge_validate.$$.out 2>/tmp/henge_validate.$$.err &
    SERVER_PID=$!
    sleep 5
    kill -TERM "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
    cat /tmp/henge_validate.$$.out /tmp/henge_validate.$$.err
    rm -f /tmp/henge_validate.$$.out /tmp/henge_validate.$$.err
  )
  set -e

  if echo "$VALIDATE_OUTPUT" | grep -q "✓ keys validated"; then
    ok "Keys validated"
  else
    echo "$VALIDATE_OUTPUT" >&2
    fail "Key validation failed. See output above (likely an invalid ANTHROPIC_API_KEY or OPENAI_API_KEY)."
  fi
fi

# ───── step 5: register MCP per host ─────
PYTHON_BIN="$HENGE_DIR/.venv/bin/python"

register_claude_code() {
  if ! command -v claude >/dev/null 2>&1; then
    warn "Claude Code CLI ('claude') not on PATH — skipping Claude Code registration."
    return 0
  fi
  if claude mcp list 2>/dev/null | grep -qE "^henge\b"; then
    say "Removing existing 'henge' Claude Code registration"
    claude mcp remove henge >/dev/null 2>&1 || true
  fi
  say "Registering Henge in Claude Code (user scope)"
  claude mcp add -s user henge -- "$PYTHON_BIN" -m henge.server
  ok "Claude Code: registered"
}

write_json_mcp_entry() {
  local cfg="$1"
  mkdir -p "$(dirname "$cfg")"
  [[ -f "$cfg" ]] || echo '{}' > "$cfg"
  "$PYTHON_BIN" - "$cfg" "$PYTHON_BIN" <<'PYEOF'
import json, sys, pathlib
cfg_path, py_bin = sys.argv[1], sys.argv[2]
p = pathlib.Path(cfg_path)
raw = p.read_text().strip() or "{}"
try:
    data = json.loads(raw)
except json.JSONDecodeError:
    print(f"!! Could not parse JSON at {cfg_path}; aborting MCP write.", file=sys.stderr)
    sys.exit(1)
data.setdefault("mcpServers", {})
data["mcpServers"]["henge"] = {
    "command": py_bin,
    "args": ["-m", "henge.server"],
}
p.write_text(json.dumps(data, indent=2) + "\n")
PYEOF
}

register_claude_desktop() {
  local cfg
  case "$(uname -s)" in
    Darwin) cfg="$HOME/Library/Application Support/Claude/claude_desktop_config.json" ;;
    Linux)  cfg="$HOME/.config/Claude/claude_desktop_config.json" ;;
    *)      warn "Claude Desktop config path unknown for $(uname -s) — skipping."; return 0 ;;
  esac
  if [[ ! -f "$cfg" && "$HOST_VALUE" != "all" && "$HOST_VALUE" != "claude-desktop" ]]; then
    return 0
  fi
  say "Adding Henge to $cfg"
  write_json_mcp_entry "$cfg"
  ok "Claude Desktop: registered"
}

register_cursor() {
  local cfg="$HOME/.cursor/mcp.json"
  if [[ ! -d "$HOME/.cursor" && "$HOST_VALUE" != "all" && "$HOST_VALUE" != "cursor" ]]; then
    return 0
  fi
  say "Adding Henge to $cfg"
  write_json_mcp_entry "$cfg"
  ok "Cursor: registered"
}

case "$HOST_VALUE" in
  auto)
    register_claude_code
    register_claude_desktop
    register_cursor
    ;;
  claude-code)    register_claude_code ;;
  claude-desktop) register_claude_desktop ;;
  cursor)         register_cursor ;;
  all)
    register_claude_code
    register_claude_desktop
    register_cursor
    ;;
  *) fail "Unknown --host: $HOST_VALUE (valid: auto|claude-code|claude-desktop|cursor|all)" ;;
esac

# ───── step 6: slash command (Claude Code only) ─────
if command -v claude >/dev/null 2>&1; then
  CMD_DIR="$HOME/.claude/commands"
  mkdir -p "$CMD_DIR"
  CMD_FILE="$CMD_DIR/decide.md"
  if [[ -f "$CMD_FILE" ]]; then
    ok "/decide slash command already exists at $CMD_FILE (kept as-is)"
  else
    cat > "$CMD_FILE" <<'CMDEOF'
---
description: Invokes Henge — disagreement map of 9 advisors + 1 dissenter.
---
Use the `decide` MCP tool from the `henge` server to analyze: $ARGUMENTS.

If the response is `status: "needs_context"`: present the `questions` to the user as a numbered list, then add a final line saying they can skip these and run immediately by replying "skip" (or "omitir" / "corre ya"). On that reply, call `decide` again with `skip_scoping=True`. Otherwise, call `decide` again with `context` set to their answers.

When the full JSON returns (status absent): cite `viz_path`, summarize the `consensus` first, list the 9 advisors' conclusions, then quote `tenth_man.response` verbatim.
CMDEOF
    ok "/decide slash command created at $CMD_FILE"
  fi
fi

# ───── step 7: summary ─────
echo
echo "──────────────────────────────────────────────"
ok "Henge installed."
EMBED="$(grep -E '^EMBED_PROVIDER=' "$ENV_FILE" 2>/dev/null | cut -d= -f2 || true)"
LOCALE="$(grep -E '^HENGE_LOCALE=' "$ENV_FILE" 2>/dev/null | cut -d= -f2 || true)"
echo "  Python:    $PY_VERSION"
echo "  Repo:      $HENGE_DIR"
echo "  Venv:      $HENGE_DIR/.venv"
echo "  Embed:     ${EMBED:-openai (default)}"
echo "  Locale:    ${LOCALE:-auto-detect from question}"
echo
echo "Next: fully quit Claude Code (close every terminal running 'claude'),"
echo "      then reopen and try:  /decide should I take the new job?"
